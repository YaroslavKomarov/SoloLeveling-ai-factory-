# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App — production: set to your Vercel/custom domain
NEXT_PUBLIC_APP_URL=http://localhost:3000

# LLM Provider: 'anthropic' (default) or 'openrouter'
AI_PROVIDER=anthropic

# Anthropic (used when AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# OpenRouter (used when AI_PROVIDER=openrouter)
# Also used by embedding-worker Edge Function for RAG embeddings (openai/text-embedding-3-small)
OPENROUTER_API_KEY=

# Optional: override default OpenRouter models
# OPENROUTER_SMART_MODEL=anthropic/claude-sonnet-4-5
# OPENROUTER_FAST_MODEL=anthropic/claude-haiku-4-5

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Production: https://{domain}/api/calendar/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/api/calendar/callback

# Token encryption (32-char hex secret)
TOKEN_ENCRYPTION_KEY=

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Use any valid email, e.g. admin@yourdomain.com
VAPID_EMAIL=

# Logging — use 'warn' or 'info' for production, 'debug' for development
LOG_LEVEL=debug
