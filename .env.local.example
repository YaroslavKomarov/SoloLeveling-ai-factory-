# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/calendar/callback

# Token encryption (32-char secret)
TOKEN_ENCRYPTION_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Logging
LOG_LEVEL=debug

# LLM Provider: 'anthropic' (default) or 'openrouter'
AI_PROVIDER=anthropic

# Anthropic (used when AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# OpenRouter (used when AI_PROVIDER=openrouter)
OPENROUTER_API_KEY=

# Optional: override default OpenRouter models
# OPENROUTER_SMART_MODEL=anthropic/claude-sonnet-4-5
# OPENROUTER_FAST_MODEL=anthropic/claude-haiku-4-5
